{
  "name": "tokenlean",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "tokenlean",
  "workspaceFolder": "/app",

  // Override the compose entrypoint so the container stays alive for dev
  // without starting the proxies immediately (use make start / manual run)
  "overrideCommand": true,

  "features": {
    // Node.js for Claude Code CLI
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    // Git
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "forwardPorts": [4444, 4445],
  "mounts": [
    // Persist GitHub Copilot OAuth token across devcontainer rebuilds
    "source=copilot-auth,target=/root/.config/litellm/github_copilot,type=volume"
  ],
  "portsAttributes": {
    "4444": {
      "label": "aip-proxy",
      "onAutoForward": "notify"
    },
    "4445": {
      "label": "LiteLLM",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/app/.venv/bin/python3",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "editor.rulers": [88],
        "terminal.integrated.defaultProfile.linux": "bash",
        // Point the Claude Code extension at the local tokenlean proxy
        "claudeCode.disableLoginPrompt": true,
        "claudeCode.environmentVariables": [
          { "name": "ANTHROPIC_AUTH_TOKEN",      "value": "litellm" },
          { "name": "ANTHROPIC_BASE_URL",         "value": "http://localhost:4444" },
          { "name": "ANTHROPIC_MODEL",            "value": "claude-sonnet-4-6" },
          { "name": "ANTHROPIC_SMALL_FAST_MODEL", "value": "gpt-4-1" }
        ]
      }
    }
  },

  // Install Claude Code CLI, rtk, and configure the proxy once the container is ready
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh && export PATH=\"$HOME/.local/bin:$PATH\" && rtk init -g --auto-patch && python3 /app/configure_claude.py apply && echo 'Dev container ready.'",

  // Start both proxies automatically when the container is opened
  // (runs on every open, not just first create — idempotent because entrypoint handles restarts)
  "postStartCommand": "/app/entrypoint.sh"
}
